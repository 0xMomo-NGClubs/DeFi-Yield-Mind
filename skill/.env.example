# ============================================================
# DeFi Yield Hub Skill — 环境变量
# 复制本文件为 .env，填入真实值后运行
# ============================================================

# Agent 执行钱包的私钥（0x 开头，64位十六进制）
# 重要：
#   - 私钥只在本地读取，用于 viem 在本机签名，不发送给任何服务器
#   - 建议使用专用测试钱包，不要使用存有大量资金的主钱包
#   - 不要将此文件提交到 git（.gitignore 已忽略 .env）
AGENT_PRIVATE_KEY=0x你的私钥填在这里

# Anthropic API Key（用于调用 Claude 模型）
# 获取：https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# DeFi Yield Hub 后端地址（默认 localhost:3000，先确保后端已启动）
# 启动后端：cd ../api && npm run dev
DEFI_API_URL=http://localhost:3000
